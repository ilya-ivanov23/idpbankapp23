# ================================================
# .env.example — ШАБЛОН (безопасно для git)
# Скопируй этот файл в .env и заполни реальными значениями:
# cp .env.example .env
# ================================================

# --- БАЗА ДАННЫХ ---
DB_USERNAME=idp_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=idp_bank_db

# --- JWT (генерируй случайные строки, например: openssl rand -hex 64) ---
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHARS

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- RESEND (email) ---
RESEND_API_KEY=re_...
